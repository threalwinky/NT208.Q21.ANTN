APP_NAME=Studify
APP_ENV=development
APP_VERSION=1.0.6

POSTGRES_USER=studify
POSTGRES_PASSWORD=studify_local_dev
POSTGRES_DB=studify
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://studify:studify_local_dev@postgres:5432/studify
BACKEND_DATABASE_URL=postgresql+psycopg2://studify:studify_local_dev@postgres:5432/studify

REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
BACKEND_REDIS_URL=redis://redis:6379/0

QDRANT_URL=http://qdrant:6333
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
BACKEND_QDRANT_URL=http://qdrant:6333

# LLM provider: gpt (mặc định) | mimo | ollama
LLM_PROVIDER=gpt

# ── GPT-5.5 (OpenAI Chat Completions-compatible router) ──
# Bắt buộc cấu hình endpoint + key tại đây (KHÔNG hardcode trong code).
GPT_BASE_URL=https://your-router.example.com/api/v1
GPT_API_KEY=replace_me
GPT_CHAT_MODEL=gpt-5.5
GPT_TIMEOUT_SECONDS=120

# ── MiMo (MiniMax) – backward compat ──
MIMO_BASE_URL=https://token-plan-ams.xiaomimimo.com/v1
MIMO_ANTHROPIC_BASE_URL=https://token-plan-ams.xiaomimimo.com/anthropic/v1
MIMO_API_KEY=replace_me
MIMO_CHAT_MODEL=mimo-v2.5-pro
MIMO_TEMPERATURE=0.2
MIMO_TOP_P=0.9
MIMO_MAX_COMPLETION_TOKENS=1200
MIMO_TIMEOUT_SECONDS=120

# Connection pooling
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_RECYCLE=1800

EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_HOST_PORT=11434
OLLAMA_CHAT_MODEL=minimax-m2.7:cloud
OLLAMA_EMBED_MODEL=nomic-embed-text
BACKEND_OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_FALLBACK_URLS=http://host.docker.internal:11434,http://10.0.0.1:11434,http://172.17.0.1:11434

JWT_SECRET=replace-this-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

CORS_ORIGINS=http://localhost:3000
BACKEND_PORT=8000
FRONTEND_PORT=3000
NGINX_PORT=8080
NEXT_PUBLIC_API_BASE_URL=/api/v1
# Khi chạy frontend ngoài Docker, đổi thành http://localhost:8000/api/v1.
INTERNAL_API_BASE_URL=http://backend:8000/api/v1

CRAWLER_USER_AGENT=StudifyBot/1.0.6 (+https://uit.edu.vn)
CRAWLER_TIMEOUT_SECONDS=25
CRAWLER_DELAY_SECONDS=1
CRAWLER_MAX_PAGES=20
CRAWLER_RETRIES=2
DATA_DIR=/app/data
KNOWLEDGE_REFRESH_POLL_SECONDS=300

ENABLE_ADMIN_DEMO=true
ENABLE_DOCUMENT_UPLOAD=true
ENABLE_EMAIL_REMINDERS=false
ENABLE_EVALUATION_RUNNER=true
# v1.0.6: streaming bật mặc định (Anthropic SSE realtime)
ENABLE_MIMO_STREAMING=true
# Web search tool – tìm internet khi RAG không đủ thông tin
ENABLE_WEB_SEARCH=true
WEB_SEARCH_MAX_RESULTS=5
ENABLE_WELLBEING=true
ENABLE_SPOTIFY=false
ENABLE_AI_NOTE_REFLECTION=false

SPOTIFY_ENABLED=false
SPOTIFY_ACCESS_TOKEN=
SPOTIFY_CLIENT_ID=replace_me
SPOTIFY_CLIENT_SECRET=replace_me
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/v1/integrations/spotify/callback
SPOTIFY_TOKEN_ENCRYPTION_KEY=replace_me
