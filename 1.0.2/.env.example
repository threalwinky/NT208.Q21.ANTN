APP_NAME=Studify
APP_ENV=development

POSTGRES_USER=studify
POSTGRES_PASSWORD=studify123
POSTGRES_DB=studify
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://studify:studify123@postgres:5432/studify

REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
QDRANT_URL=http://qdrant:6333
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

OLLAMA_BASE_URL=http://host.docker.internal:11435
OLLAMA_HOST_PORT=11434
OLLAMA_PROXY_PORT=11435
OLLAMA_CHAT_MODEL=minimax-m2.7:cloud
OLLAMA_EMBED_MODEL=nomic-embed-text

JWT_SECRET=replace-this-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

CORS_ORIGINS=http://localhost:3000
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

CRAWLER_USER_AGENT=StudifyBot/1.0 (+https://uit.edu.vn)
CRAWLER_TIMEOUT_SECONDS=25
CRAWLER_DELAY_SECONDS=1
CRAWLER_MAX_PAGES=20
CRAWLER_RETRIES=2
DATA_DIR=/app/data
KNOWLEDGE_REFRESH_POLL_SECONDS=300
SPOTIFY_ENABLED=true
SPOTIFY_ACCESS_TOKEN=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
